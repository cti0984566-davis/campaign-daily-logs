{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Campaign Log Schema v1.0",
  "type": "object",
  "required": ["date", "timezone", "campaign", "items"],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "timezone": {
      "type": "string",
      "minLength": 1
    },
    "campaign": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cluster": {
          "type": "string"
        },
        "suspected_actor": {
          "type": "string"
        },
        "attribution_confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        }
      },
      "additionalProperties": false
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/item"
      }
    }
  },
  "definitions": {
    "item": {
      "type": "object",
      "required": [
        "id",
        "type",
        "status",
        "name",
        "sources"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}_[a-z0-9_\\-]+$"
        },
        "type": {
          "type": "string",
          "enum": ["campaign_activity", "incident", "assessment", "alert", "policy", "business_tech"]
        },
        "status": {
          "type": "string",
          "enum": ["新規", "継続", "更新"]
        },
        "name": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "targeting": {
          "type": "object",
          "properties": {
            "regions": {
              "type": "array",
              "items": { "type": "string" }
            },
            "industries": {
              "type": "array",
              "items": { "type": "string" }
            },
            "organization_types": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "first_seen": {
          "type": "string"
        },
        "last_seen": {
          "type": "string"
        },
        "activity_summary": {
          "type": "string"
        },
        "activity_details": {
          "type": "string"
        },
        "ttp": {
          "type": "array",
          "items": { "type": "string" }
        },
        "malware_and_tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "infrastructure": {
          "type": "array",
          "items": { "type": "string" }
        },
        "iocs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "strategic_view": {
          "type": "object",
          "properties": {
            "general": { "type": "string" },
            "geopolitical": { "type": "string" },
            "business": { "type": "string" },
            "research_direction": { "type": "string" }
          },
          "additionalProperties": false
        },
        "assessment": {
          "type": "object",
          "properties": {
            "significance": {
              "type": "string",
              "enum": ["low", "medium", "high", "critical"]
            },
            "confidence": {
              "type": "string",
              "enum": ["low", "medium", "high"]
            },
            "why_it_matters": {
              "type": "string"
            },
            "delta_from_previous": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "related_campaigns": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["title", "url"],
            "properties": {
              "title": { "type": "string" },
              "url": { "type": "string" },
              "publisher": { "type": "string" },
              "published_at": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "diamond_model": {
          "type": "object",
          "properties": {
            "adversary": {
              "type": "string"
            },
            "infrastructure": {
              "type": "array",
              "items": { "type": "string" }
            },
            "capability": {
              "type": "array",
              "items": { "type": "string" }
            },
            "victim": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
