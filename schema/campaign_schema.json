{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Campaign Daily Log Schema v1.0",
  "type": "object",
  "required": ["date", "timezone", "title", "items"],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "timezone": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/item"
      }
    }
  },
  "definitions": {
    "item": {
      "type": "object",
      "required": [
        "id",
        "type",
        "status",
        "campaign",
        "name",
        "summary",
        "sources"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["campaign_activity", "incident", "policy", "business_tech", "assessment"]
        },
        "status": {
          "type": "string",
          "enum": ["新規", "継続", "更新"]
        },
        "campaign": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "aliases": {
              "type": "array",
              "items": { "type": "string" }
            },
            "cluster": { "type": "string" },
            "suspected_actor": { "type": "string" },
            "attribution_confidence": {
              "type": "string",
              "enum": ["low", "medium", "high"]
            }
          },
          "additionalProperties": false
        },
        "name": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "industry": {
          "type": "array",
          "items": { "type": "string" }
        },
        "region": {
          "type": "array",
          "items": { "type": "string" }
        },
        "first_seen": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "last_seen": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "summary": {
          "type": "string"
        },
        "details": {
          "type": "string"
        },
        "actors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" },
              "country": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "ttp": {
          "type": "array",
          "items": { "type": "string" }
        },
        "malware": {
          "type": "array",
          "items": { "type": "string" }
        },
        "infrastructure": {
          "type": "array",
          "items": { "type": "string" }
        },
        "targeting": {
          "type": "object",
          "properties": {
            "sectors": {
              "type": "array",
              "items": { "type": "string" }
            },
            "countries": {
              "type": "array",
              "items": { "type": "string" }
            },
            "organization_types": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "strategic_view": {
          "type": "object",
          "properties": {
            "general": { "type": "string" },
            "geopolitical": { "type": "string" },
            "business": { "type": "string" },
            "research_direction": { "type": "string" }
          },
          "additionalProperties": false
        },
        "assessment": {
          "type": "object",
          "properties": {
            "significance": {
              "type": "string",
              "enum": ["low", "medium", "high", "critical"]
            },
            "confidence": {
              "type": "string",
              "enum": ["low", "medium", "high"]
            },
            "why_it_matters": { "type": "string" },
            "delta_from_previous": { "type": "string" }
          },
          "additionalProperties": false
        },
        "related_campaigns": {
          "type": "array",
          "items": { "type": "string" }
        },
        "related_reports": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["title", "url"],
            "properties": {
              "title": { "type": "string" },
              "url": { "type": "string" },
              "publisher": { "type": "string" },
              "published_at": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}